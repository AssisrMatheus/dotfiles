[user]
	email = 12276174+AssisrMatheus@users.noreply.github.com
	name = AssisrMatheus
[pull]
	rebase = false
[filter "lfs"]
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
[core]
	editor = nvim
	# Delta as the pager for plain `git diff`, `git log -p`, etc.
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
	side-by-side = true
	line-numbers = true
	hyperlinks = true
[merge]
	# diffview's mergetool provides JetBrains-style LOCAL | MERGED | REMOTE panes.
	# Falls back to plain nvimdiff if nvim/diffview is unavailable.
	tool = diffview
	conflictstyle = diff3
[mergetool "diffview"]
	cmd = nvim -n -c "DiffviewOpen" "$MERGED"
[mergetool "nvimdiff"]
	cmd = nvim -d $LOCAL $BASE $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'
[mergetool]
	prompt = false
	keepBackup = false
[diff]
	tool = diffview
	colorMoved = default
[difftool "diffview"]
	cmd = nvim -n -c "DiffviewOpen" "$MERGED"
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
